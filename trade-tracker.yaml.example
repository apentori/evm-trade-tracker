# Trade Tracker configuration
# Priority: CLI flags > environment variables > YAML file > defaults

alchemy:
  url: "https://opt-mainnet.g.alchemy.com/v2"
  api_key: ""                     # or set ALCHEMY_API_KEY env var

wallet_address: ""                # or set WALLET_ADDRESS env var, or use -w flag

# Define one or more trading pairs to detect.
# A pair = base_token (what you're buying/selling) + quote_token (what you're paying/receiving).
# The wallet must move both tokens in a transaction for a trade to be recorded.
pairs:
  - name: "ETH/USDC"
    base_token: "0x4200000000000000000000000000000000000006"
    quote_token: "0x0b2c639c533813f4aa9d7837caf62653d097ff85"
    base_decimals: 18
    quote_decimals: 6

  - name: "OP/USDC"
    base_token: "0x4200000000000000000000000000000000000042"
    quote_token: "0x0b2c639c533813f4aa9d7837caf62653d097ff85"
    base_decimals: 18
    quote_decimals: 6

  # Arbitrum example:
  # - name: "ETH/USDC"
  #   base_token: "0x82aF49447D8a07e3bd95BD0d56f35241523fBab1"
  #   quote_token: "0xaf88d065e77c8cC2239327C5EDb3A432268e5831"
  #   base_decimals: 18
  #   quote_decimals: 6

events:
  topic_types:
    "0x40e9cecb9f5f1f1c5b9c97dec2917b7ee92e57ba5563708daca94dd84ad7112f": "SWAP"
    "0xddf252ad1be2c89b69c2b068fc378daa952ba7f163c4a11628f55a4df523b3ef": "TRANSFER"
    "0x7fcf532c15f0a6db0bd6d0e038bea71d30d808c7d98cb3bf7268a95bf5081b65": "WITHDRAWAL"

null_address: "0x0000000000000000000000000000000000000000"

clickhouse:
  host: "localhost"
  port: 9000
  user: "default"
  password: ""
  database: "default"
  table: "trades"

log_level: "INFO"
