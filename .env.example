# Trade Tracker configuration
# Environment variables override YAML config and defaults.
# See trade-tracker.yaml.example for the YAML-equivalent keys.

ALCHEMY_URL=https://opt-mainnet.g.alchemy.com/v2
ALCHEMY_API_KEY=
WALLET_ADDRESS=

# Token addresses (env vars override YAML token config)
USDC_ADDRESS=0x0b2c639c533813f4aa9d7837caf62653d097ff85
USDC_OLD_ADDRESS=0xda10009cbd5d07dd0cecc66161fc93d7c9000da1
